DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_ALLOWED_USER_ID=123456789012345678
# Use `main` in the `main/` checkout and `staging` in the `staging/` checkout.
BOT_ROLE=main_or_staging
CODEX_DISCORD_CONFIG=config/config.json
DISCORD_GUILD_ID=
LOG_LEVEL=INFO
# Optional. If set, the file contents are passed to Codex app-server as developerInstructions.
CODEX_DISCORD_DEVELOPER_INSTRUCTIONS_FILE=

[Unit]
Description=Codex Discord Main Bot
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/srv/codex-discord/prod
EnvironmentFile=/srv/codex-discord/prod/.env
ExecStart=/srv/codex-discord/prod/.venv/bin/python /srv/codex-discord/prod/app.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
